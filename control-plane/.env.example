# Copy to .env and fill in real values. Never commit the real .env.

# Postgres superuser password, and also used for the authenticator /
# supabase_auth_admin roles created in schema.sql (kept identical for
# simplicity in this minimal stack -- rotate independently in production
# by editing schema.sql's role creation).
POSTGRES_PASSWORD=change-me-to-a-long-random-string

# Shared HMAC secret GoTrue signs JWTs with and PostgREST verifies them
# against. Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string

# The two API keys @supabase/supabase-js expects. These are themselves JWTs
# signed with JWT_SECRET above -- generate at https://supabase.com/docs/guides/self-hosting/docker#api-keys
# or with the `jwt` CLI. ANON_KEY carries role=anon, SERVICE_ROLE_KEY carries
# role=service_role (bypasses RLS -- never ship this to any client, admin use
# only, e.g. for the invite-creation script).
ANON_KEY=
SERVICE_ROLE_KEY=

# Public URL collaborators' Veridian clients will be configured with
# (the `proxy` service's exposed port/domain).
SITE_URL=https://your-domain-or-ip:8000

# Outbound SMTP for invite/magic-link emails (any free-tier transactional
# email provider works: Brevo, Resend, Mailgun sandbox, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
