# Copy to .env and fill in real values. Never commit the real .env.

# Postgres superuser password, and also used for the authenticator /
# supabase_auth_admin roles created automatically by init/01-roles.sh on
# first container startup (kept identical for simplicity in this minimal
# stack -- rotate independently in production by editing that script).
# Use alphanumeric characters only if you'll ever copy/paste this value into
# a Windows terminal -- spaces/quotes there are a headache to escape.
POSTGRES_PASSWORD=change-me-to-a-long-random-string

# Shared HMAC secret GoTrue signs JWTs with and PostgREST verifies them
# against. Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string

# The two API keys @supabase/supabase-js expects. These are themselves JWTs
# signed with JWT_SECRET above -- generate locally with:
#   node scripts/generate-keys.mjs "<your JWT_SECRET>"
# ANON_KEY carries role=anon, SERVICE_ROLE_KEY carries role=service_role
# (bypasses RLS -- never ship this to any client, admin use only, e.g. for
# scripts/invite-user.mjs).
ANON_KEY=
SERVICE_ROLE_KEY=

# Public URL collaborators' Veridian clients will be configured with
# (the `proxy` service's exposed port/domain).
SITE_URL=http://localhost:8000

# Outbound SMTP for invite/magic-link emails (any free-tier transactional
# email provider works: Brevo, Resend, Mailgun sandbox, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
